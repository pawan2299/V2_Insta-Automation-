# Example environment variables for Krishna Bot
#
# IMPORTANT:
# - Do NOT commit real secrets. This file is a template with placeholders only.
# - Copy this to a local `.env` (which is in .gitignore) and fill in real values.
# - If any of your secrets have been shared publicly (for example, in chat or PRs), rotate them immediately.

# App & deployment
APP_ENV=production
PUBLIC_BASE_URL=https://your-deploy-url.example.com
PORT=10000
LOG_LEVEL=INFO

# Instagram / Facebook (Meta)
# ACCESS_TOKEN is kept for backward compatibility. Prefer IG_USER_ACCESS_TOKEN and PAGE_ACCESS_TOKEN.
ACCESS_TOKEN=
IG_USER_ACCESS_TOKEN=
PAGE_ACCESS_TOKEN=
PAGE_ID=
OWN_ACCOUNT_ID=
VERIFY_TOKEN=

# App security
APP_SECRET=
DM_ACCESS_TOKEN=

# Gemini / Google GenAI
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# Database (neon.tech / PostgreSQL)
# Example: postgresql://user:pass@host:port/dbname?sslmode=require
DATABASE_URL=

# Telegram (admin control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: add any other environment variables required by your deployment

# Troubleshooting notes:
# - The real .env file must not be committed. .gitignore already excludes .env and .env.*.
# - After updating .env locally, redeploy your service (Render/other provider) with these envs set in the platform.
